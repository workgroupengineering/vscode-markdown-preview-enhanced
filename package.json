          "scope": "machine"
        },
        "markdown-preview-enhanced.d2Layout": {
          "description": "%markdown-preview-enhanced.d2Layout.description%",
          "default": "dagre",
          "type": "string",
          "enum": [
            "dagre",
            "elk",
            "tala"
          ]
        },
        "markdown-preview-enhanced.d2Theme": {
          "description": "%markdown-preview-enhanced.d2Theme.description%",
          "default": 0,
          "type": "number",
          "enum": [
            0,
            1,
            3,
            4,
            5,
            6,
            7,
            8,
            100,
            101,
            102,
            103,
            104,
            105,
            200,
            201,
            300,
            301,
            302,
            303
          ],
          "enumItemLabels": [
            "Neutral Default",
            "Neutral Grey",
            "Flagship Terrastruct",
            "Cool Classics",
            "Mixed Berry Blue",
            "Grape Soda",
            "Aubergine",
            "Colorblind Clear",
            "Vanilla Nitro Cola",
            "Orange Creamsicle",
            "Shirley Temple",
            "Earth Tones",
            "Everglade Green",
            "Buttered Toast",
            "Dark Mauve",
            "Dark Flagship Terrastruct",
            "Terminal",
            "Terminal Grayscale",
            "Origami",
            "C4"
          ]
        },
        "markdown-preview-enhanced.d2Sketch": {
          "description": "%markdown-preview-enhanced.d2Sketch.description%",
          "default": false,
          "type": "boolean"
        },
        "markdown-preview-enhanced.markdownFileExtensions": {
          "description": "%markdown-preview-enhanced.markdownFileExtensions.description%",
          "default": [
            ".md",
            ".markdown",
            ".mdown",
            ".mkdn",
            ".mkd",
            ".rmd",
            ".qmd",
            ".mdx"
          ],
          "type": "array"
        },
        "markdown-preview-enhanced.alwaysShowBacklinksInPreview": {
          "description": "%markdown-preview-enhanced.alwaysShowBacklinksInPreview.description%",
          "default": false,
          "type": "boolean"
        },
        "markdown-preview-enhanced.enablePreviewZenMode": {
          "description": "%markdown-preview-enhanced.enablePreviewZenMode.description%",
          "default": true,
          "type": "boolean"
        },
        "markdown-preview-enhanced.useVSCodeThemeForContextMenu": {
          "description": "%markdown-preview-enhanced.useVSCodeThemeForContextMenu.description%",
          "default": false,
          "type": "boolean"
        },
        "markdown-preview-enhanced.enableImageLightbox": {
          "description": "%markdown-preview-enhanced.enableImageLightbox.description%",
          "default": true,
          "type": "boolean"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "markdown-preview-enhanced",
        "displayName": "%customEditorPreviewDisplayName%",
        "selector": [
          {
            "filenamePattern": "*.{md,markdown,mdown,mkdn,mkd,rmd,qmd}"
          }
        ],
        "priority": "option"
      }
    ],
    "keybindings": [
      {
        "command": "markdown-preview-enhanced.openPreviewToTheSide",
        "key": "ctrl+k v",
        "mac": "cmd+k v",
        "when": "editorLangId =~ /^(markdown|quarto|prompt|instructions|chatagent|skill)$/"
      },
      {
        "command": "markdown-preview-enhanced.openPreview",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorLangId =~ /^(markdown|quarto|prompt|instructions|chatagent|skill)$/"
      },
      {
        "command": "markdown-preview-enhanced.openLockedPreviewToTheSide",
        "key": "ctrl+k shift+l",
        "mac": "cmd+k shift+l",
        "when": "editorLangId =~ /^(markdown|quarto|prompt|instructions|chatagent|skill)$/"
      },
      {
        "command": "markdown-preview-enhanced.togglePreviewLock",
        "key": "ctrl+k ctrl+shift+l",
        "mac": "cmd+k cmd+shift+l",
        "when": "editorLangId =~ /^(markdown|quarto|prompt|instructions|chatagent|skill)$/"
      },
      {
        "command": "markdown-preview-enhanced.runAllCodeChunks",
        "key": "ctrl+shift+enter",
        "when": "editorLangId =~ /^(markdown|quarto|prompt|instructions|chatagent|skill)$/"
      },
      {
        "command": "markdown-preview-enhanced.runCodeChunk",
        "key": "shift+enter",
        "when": "editorLangId =~ /^(markdown|quarto|prompt|instructions|chatagent|skill)$/"
      },
      {
        "command": "markdown-preview-enhanced.syncPreview",
        "key": "ctrl+shift+s",
        "when": "editorLangId =~ /^(markdown|quarto|prompt|instructions|chatagent|skill)$/"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "markdown-preview-enhanced.openPreviewToTheSide",
          "when": "editorLangId =~ /^(markdown|quarto|prompt|instructions|chatagent|skill)$/",
          "group": "markdown-preview-enhanced"
        },
        {
          "command": "markdown-preview-enhanced.openGraphView",
          "when": "editorLangId =~ /^(markdown|quarto|prompt|instructions|chatagent|skill)$/",
          "group": "markdown-preview-enhanced"
        }
      ],
      "editor/title": [
        {
          "command": "markdown-preview-enhanced.openPreviewToTheSide",
          "when": "editorLangId =~ /^(markdown|quarto|prompt|instructions|chatagent|skill)$/",
          "group": "navigation"
        }
      ]
    }
  },
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:markdown",
    "onLanguage:quarto",
    "onLanguage:prompt",
    "onLanguage:instructions",
    "onLanguage:chatagent",
    "onLanguage:skill"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
